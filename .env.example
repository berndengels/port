MONTH_SAISON_START=6 # Juni
MONTH_SAISON_END=9 # September
CARAVAN_PRICE_ELECTRIC_PER_DAY=2
CARAVAN_PRICE_ADDITIONAL_PERSONS_PER_DAY=1
CARAVAN_PRICE_PERSONS_INCLUSIVE=2
CARAVAN_PRICE_DEFAULT='{"4":12, "5":12, "6":12, "7":12, "8":12, "9":12, "10":12, "11":12, "12":12}'
CARAVAN_MIN_PRICE_DEAULT=12
CARAVAN_MAX_PRICE_DEAULT=12

CARAVAN_PRICE_SAISON='{"4":15, "5":15, "6":15, "7":15, "8":15, "9":15, "10":15, "11":15, "12":15}'
CARAVAN_MIN_PRICE_SAISON=15
